{
  "rewrites": [
    {
      "source": "/gh/login/device/code",
      "destination": "https://github.com/login/device/code"
    },
    {
      "source": "/gh/login/oauth/access_token",
      "destination": "https://github.com/login/oauth/access_token"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
